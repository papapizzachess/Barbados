   "source": [
    "from pathlib import Path\n",
    "\n",
    "folder = Path(\"masks_full_json\")\n",
    "\n",
    "for file in folder.glob(\"*.png\"):\n",
    "    new_name = file.name.split(\"_\")[-1]\n",
    "    target = folder / new_name\n",
    "\n",
    "    if not target.exists():\n",
    "        file.rename(target)\n",
    "    else:\n",
    "        print(f\"Skipping duplicate: {file.name}\")"
   ]
